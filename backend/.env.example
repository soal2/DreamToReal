# =============================================
# Dream-to-Real 后端环境变量模板
# 复制此文件为 backend/.env 后按需填值；留空则使用代码默认值
# =============================================

# ========== 基础服务 ==========
# 服务监听地址。本地开发可填 127.0.0.1；容器/线上保持 0.0.0.0
DTR_HOST=
# 服务监听端口，默认 8000
DTR_PORT=
# 跨域白名单，多个域名用英文逗号分隔；开发期可填 *，生产建议显式列举前端域名
DTR_CORS_ALLOW_ORIGINS=
# 日志级别，可选值：DEBUG / INFO / WARNING / ERROR
DTR_LOG_LEVEL=

# ========== 存储路径 ==========
# SQLite 数据库文件路径，留空使用 backend/var/dream_to_real.sqlite3
DTR_DATABASE_PATH=
# 静态资源根目录（生成图片最终落盘位置），留空使用 backend/static
DTR_STATIC_DIR=

# ========== 大语言模型（梦境整理）==========
# Provider 标识：mock | dashscope | openai | ...；mock 模式无需填后续 API_KEY
DTR_LLM_PROVIDER=mock
# 真实 Provider 接入时必填；mock 模式留空
DTR_LLM_API_KEY=
# 真实 Provider 的 Base URL；使用官方默认端点时可留空
DTR_LLM_BASE_URL=
# 模型名，如 qwen-max / gpt-4o-mini / glm-4 等
DTR_LLM_MODEL=
# 单次 LLM 请求超时时间（秒），默认 30
DTR_LLM_TIMEOUT_SECONDS=

# ========== 图像生成 ==========
# Provider 标识：mock | openai | stepfun ...；mock 模式无需填后续 API_KEY
DTR_IMAGE_PROVIDER=mock
# 真实 Provider 接入时必填；mock 模式留空
DTR_IMAGE_API_KEY=
# 真实 Provider 的 Base URL；使用官方默认端点时可留空
DTR_IMAGE_BASE_URL=
# 模型名，如 dall-e-3；StepFun 可选 step-2x-large / step-1x-medium / step-image-edit-2
DTR_IMAGE_MODEL=
# 单次出图请求超时时间（秒），默认 60
DTR_IMAGE_TIMEOUT_SECONDS=
# ---- 以下为 StepFun 可选参数（留空使用服务端默认） ----
# classifier-free guidance scale, StepFun 取值 1~10
DTR_IMAGE_CFG_SCALE=
# 生成步数, StepFun 取值 1~50
DTR_IMAGE_STEPS=
# 随机种子, 留空使用随机
DTR_IMAGE_SEED=
# 自定义输出尺寸 (覆盖默认 1024x1024)，例如 1280x800
DTR_IMAGE_SIZE=
# 瞬时错误重试次数, 默认 2
DTR_IMAGE_MAX_RETRIES=
